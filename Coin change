#include <bits/stdc++.h>
using namespace std;
using ll = long long;

int a[1000007];
int dp[1000007];

int main(){

    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

     int n, s; cin >> n >> s;
     for(int i = 1; i <= n; i++){
        cin >> a[i];
     }
     dp[0] = 0;
     for(int i = 1; i <= s; i++){
        dp[i] = 1e9;
     }
     for(int i = 1; i <= n; i++){
        for(int j = a[i]; j <= s; j++){
            dp[j] = min(dp[j], dp[j-a[i]] + 1) ;
           
        }
     }

     if(dp[s] == 1e9) cout << "-1";
     else cout << dp[s];

    return 0;
}
