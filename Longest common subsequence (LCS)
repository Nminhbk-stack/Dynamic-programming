#include <bits/stdc++.h>
using namespace std;
using ll = long long;

int dp[1007][1007];

int main(){

    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

     string s, t;
     cin >> s >> t;
     int n = s.size(); int m= t.size();
     s = " " + s;
     t = " " + t;

     int i = 1; int j = 1;

     for(int i = 1; i <= n; i++){
        for(int j = 1; j <= m; j++){
            if(s[i] == t[j]){
                dp[i][j] = dp[i-1][j-1] + 1;
            }
            else{
                dp[i][j] = max(dp[i-1][j], dp[i][j-1]);
            }
        }
     }

     cout << dp[n][m];


    return 0;
}
