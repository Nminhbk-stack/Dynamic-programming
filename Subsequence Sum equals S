#include <bits/stdc++.h>
using namespace std;
using ll = long long;

int a[1007];
int dp[100007];

int main(){

    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

     int n, s;
     cin >> n >> s;
     for(int i = 0; i <n; i++){
        cin >> a[i];
     }
     dp[0] = 1;
     for(int i = 0; i < n; i++){
        for(int j = s; j >= a[i]; j--){
            if(dp[j-a[i]] == 1) dp[j] = 1;
        }
     }

     cout << dp[s];


    return 0;
}
