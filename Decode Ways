#include <bits/stdc++.h>
using namespace std;
using ll = long long;
ll MOD = 1e9+7;

ll dp[1000007];


int main(){

    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    string s; cin >> s;
    int len = s.size();

    if(s[0] == '0'){
        cout << "0";
        return 0;
    }
    dp[0] = 1;

    for(int i = 1; i<len; i++){
        if(s[i] == '0' && i >= 2){
            if(10*(s[i-1] - '0') > 26 || 10*(s[i-1] - '0') < 10){
                cout << "0";
                return 0;
            }
            else{
                dp[i] = dp[i-2];
            }

        }
        else if(s[i] == '0' && i == 1){
            if(10*(s[i-1] - '0') <= 26 && 10*(s[i-1] - '0') >= 10) dp[i] = dp[i-1];
            else{
                cout << "0";
                return 0;
            }
        }
        else{
            dp[i] = dp[i-1];

            if(i >= 2 && 10*(s[i-1] - '0') + (s[i] - '0') <= 26 && 10*(s[i-1] - '0') + (s[i] - '0') >= 10 ){
                dp[i] += dp[i-2];
                dp[i] %= MOD;
            }
            if(i == 1){
                if(10*(s[0] - '0') + (s[1] - '0') <= 26) dp[i] += 1;
            }
        }
    }
    cout << dp[len-1];

    return 0;
}
