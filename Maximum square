#include <bits/stdc++.h>
using namespace std;

using ll = long long;
int a[507][507];
ll dp[507][507];


int main(){
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

     int n, m; cin >> n >> m;
     bool ok = false;
     for(int i = 1; i<= n; i++){
        for(int j = 1; j <= m; j++){
            cin >> a[i][j];
            if(a[i][j] == 1) ok = true;
        }
     }
     if(!ok){
        cout << "0"; 
        return 0;
     }

     ll res = -1;;
     for(int i = 1; i <= n; i ++){
        for(int j = 1; j <= m; j++){
            if(a[i][j] == 1){
                dp[i][j] = min({dp[i-1][j], dp[i][j-1], dp[i-1][j-1]}) + 1;
                res = max(res, dp[i][j]);
            }
        }
     }
     cout << res;

    return 0;
}
