#include <bits/stdc++.h>
using namespace std;
using ll = long long;

ll a[1000007];

int main(){

    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

     int n; cin >> n;
     for(int i = 1; i <= n; i++){
        cin >> a[i];
     }
     vector<int> tail;
     for(int i = 1; i <= n; i++){
        auto it = lower_bound(tail.begin(), tail.end(), a[i]);
        if(it == tail.end()){
            tail.push_back(a[i]);
        }
        else{
            *it = a[i];
        }
     }

     cout << tail.size();



    return 0;
}
